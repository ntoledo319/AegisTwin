# AegisTwin .gitignore
# Prevents reintroduction of PII and sensitive data

# ============================================
# PII QUARANTINE - NEVER COMMIT THESE
# ============================================
graveyard/
*.sqlite
*.db
*.sqlite3
*messages*.csv
*messages*.json
*conversation*.txt
*contact*.json
*raw_data*
summarized_conversations/
chat_sessions/
exports/

# Data files that may contain PII
*.mbox
*.eml
*.vcf
*.ics

# Large data archives
*.zip
*.tar.gz
*.7z

# ============================================
# Build & Runtime Artifacts
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Logs
logs/
*.log

# Local config
.env
.env.local
*.local.yaml

# Snapshots and telemetry
snapshots/
*.mmap

# Run artifacts (generated fresh each demo)
runs/

# Cache
cache/
.cache/
*.cache

# Reports and results (regenerated)
reports/
results/

# Coverage reports
htmlcov/
coverage.xml
.coverage
