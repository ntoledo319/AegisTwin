# Production Environment Variables for Cognitive-Twin

# API Keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Database Passwords
POSTGRES_PASSWORD=your_secure_postgres_password_here
MONGODB_PASSWORD=your_secure_mongodb_password_here
NEO4J_PASSWORD=your_secure_neo4j_password_here
REDIS_PASSWORD=your_secure_redis_password_here

# Monitoring Passwords
GRAFANA_PASSWORD=your_secure_grafana_password_here

# Security
SECRET_KEY=your_very_secure_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here

# Environment
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Database URLs (will be overridden by docker-compose)
POSTGRES_URL=postgresql://cognitive_twin:${POSTGRES_PASSWORD}@localhost:5432/cognitive_twin
MONGODB_URL=mongodb://cognitive_twin:${MONGODB_PASSWORD}@localhost:27017/cognitive_twin
NEO4J_URL=bolt://localhost:7687
REDIS_URL=redis://localhost:6379

# Application Settings
MAX_CONNECTIONS=100
WORKER_PROCESSES=4
TIMEOUT=30

# Monitoring
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
ELASTICSEARCH_ENABLED=true

# Backup Settings
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# SSL/TLS
SSL_ENABLED=true
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# CORS
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_CREDENTIALS=true

# File Upload
MAX_UPLOAD_SIZE=100MB
ALLOWED_FILE_TYPES=json,csv,txt,pdf,doc,docx

# AI Settings
AI_MODEL_TIMEOUT=30
AI_MAX_TOKENS=4000
AI_TEMPERATURE=0.7

# Memory Settings
MEMORY_CACHE_SIZE=1000
MEMORY_TTL=3600
VECTOR_MEMORY_SIZE=10000

# Event System
EVENT_BUS_ENABLED=true
EVENT_PERSISTENCE=true
EVENT_TTL=86400

# WebSocket Settings
WEBSOCKET_ENABLED=true
WEBSOCKET_HEARTBEAT_INTERVAL=30
WEBSOCKET_MAX_CONNECTIONS=1000
