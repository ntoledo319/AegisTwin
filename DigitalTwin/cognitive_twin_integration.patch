+                logger.info(f"Successfully imported {module_path}")
+            else:
+                logger.warning(f"Could not find module {module_path}")
+                setattr(self, attr_name, None)
+        except Exception as e:
+            logger.error(f"Error importing {module_path}: {str(e)}")
+            setattr(self, attr_name, None)
