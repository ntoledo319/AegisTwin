# Environment variables for the Integrated Data Analysis & Digital Twin System

# Application settings
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=debug

# Server settings
HOST=0.0.0.0
PORT=8000

# Database settings
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/integrated_system
MONGODB_URI=mongodb://localhost:27017/integrated_system
REDIS_URL=redis://localhost:6379/0
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Storage settings
DATA_DIR=data
CACHE_DIR=cache
LOGS_DIR=logs
RESULTS_DIR=results
TEMP_DIR=temp

# Security settings
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# API settings
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8050

# Web interface settings
WEB_HOST=0.0.0.0
WEB_PORT=3000

# External services
OPENAI_API_KEY=your-openai-api-key-here
GOOGLE_API_KEY=your-google-api-key-here